// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Postgres-compatible — no SQLite-specific syntax used.
// Switch datasource provider to "postgresql" and update DATABASE_URL for production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// SQLite FTS5 notes
// ---------------------------------------------------------------------------
// We use an SQLite FTS5 virtual table for keyword fallback search over chunk content.
// Prisma does not manage FTS5 virtual tables in the schema; see the raw SQL migration
// under `prisma/migrations/*/migration.sql`.

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum RagStatus {
  PENDING
  INDEXING
  READY
  ERROR
}

enum DocumentStatus {
  QUEUED
  PROCESSING
  READY
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum Provider {
  ANTHROPIC
  OPENAI
  GOOGLE
  MISTRAL
  LOCAL
}

// ---------------------------------------------------------------------------
// Auth models (NextAuth v5 / Auth.js adapter)
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  image          String?
  password       String?               // bcrypt hash — null for OAuth users
  onboardingDone Boolean   @default(false)
  displayName    String?
  avatarUrl      String?
  bio            String?
  theme          String    @default("light")
  lastLoginAt    DateTime?
  lastLoginIp    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  rags           Rag[]
  apiKeys        ApiKey[]
  userApiKeys    UserApiKey[]
  conversations  Conversation[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// RAG configuration
// ---------------------------------------------------------------------------

model Rag {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  emoji       String?   @default("🤖")
  tags        Json      @default("[]") // string[] stored as JSON array

  // Model configuration
  provider     String  // mirrors Provider enum — stored as string for Sqlite compat
  model        String
  temperature  Float   @default(0.7)
  maxTokens    Int     @default(1000)
  topP         Float   @default(1.0)
  systemPrompt String? @default("You are a helpful AI assistant.")
  strictMode   Boolean @default(false)

  // Retrieval settings
  chunkSize       Int     @default(500)
  chunkOverlap    Int     @default(50)
  topK            Int     @default(5)
  threshold       Float   @default(0.7)
  enableReranking Boolean @default(false)
  embeddingModel  String  @default("text-embedding-3-small")

  // Safety & limits
  maxTurns     Int    @default(10)
  rateLimit    Int    @default(60)   // requests per minute
  filterLevel  String @default("MEDIUM")
  citationMode String @default("INLINE")

  status    RagStatus @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents     Document[]
  conversations Conversation[]
  shareLinks    ShareLink[]
}

// ---------------------------------------------------------------------------
// Documents, Chunks, Embeddings
// ---------------------------------------------------------------------------

model Document {
  id         String         @id @default(cuid())
  ragId      String
  name       String
  size       Int
  type       String
  status     DocumentStatus @default(QUEUED)
  chunkCount Int            @default(0)
  errorMessage String?
  storageProvider String     @default("local")
  storageKey      String?
  metadata   Json?          // typed as DocumentMetadata in lib/types.ts

  createdAt DateTime @default(now())

  rag    Rag     @relation(fields: [ragId], references: [id], onDelete: Cascade)
  chunks Chunk[]
}

model Chunk {
  id         String   @id @default(cuid())
  documentId String
  content    String
  index      Int
  tokenCount Int      @default(0)
  metadata   Json?    // typed as ChunkMetadata in lib/types.ts

  createdAt DateTime @default(now())

  document  Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embedding Embedding?
}

model Embedding {
  id        String   @id @default(cuid())
  chunkId   String   @unique
  vector    String   // JSON-serialised Float32Array — swap to vector type in prod
  model     String   // e.g. "text-embedding-3-small"
  createdAt DateTime @default(now())

  chunk Chunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Conversations & Messages
// ---------------------------------------------------------------------------

model Conversation {
  id        String   @id @default(cuid())
  ragId     String
  userId    String
  title     String?  @default("New Conversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rag      Rag       @relation(fields: [ragId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  sources        Json?       // typed as MessageSource[] in lib/types.ts
  tokenUsage     Int         @default(0)
  responseTimeMs Int         @default(0)
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// API keys (platform-level, hashed)
// ---------------------------------------------------------------------------

/// Platform API keys issued to users — stored as SHA-256 hash + prefix.
/// Never store the raw key; show it exactly once on creation.
model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique // SHA-256(key) hex
  keyPrefix  String            // first 8 chars of raw key, e.g. "rag_ABCD"
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// User-supplied provider keys — encrypted with AES-256-GCM.
/// One record per provider per user; unique IV per row.
model UserApiKey {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // mirrors Provider enum
  encryptedKey String   // AES-256-GCM ciphertext (hex)
  iv           String   // 12-byte GCM IV (hex)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// ---------------------------------------------------------------------------
// Public share links
// ---------------------------------------------------------------------------

model ShareLink {
  id           String    @id @default(cuid())
  ragId        String
  token        String    @unique // cryptographically random, URL-safe
  passwordHash String?           // bcrypt hash — null means no password
  expiresAt    DateTime?
  clickCount   Int       @default(0)
  createdAt    DateTime  @default(now())

  rag Rag @relation(fields: [ragId], references: [id], onDelete: Cascade)
}