# Copy this file to .env and fill in real values.
# Never commit .env to source control.

# ── Database ───────────────────────────────────────────────────────────────
# SQLite (dev):
DATABASE_URL="file:./dev.db"
# Postgres (prod) — switch datasource provider in schema.prisma too:
# DATABASE_URL="postgresql://user:password@host:5432/ragify?schema=public"

# ── NextAuth / Auth.js ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ── Encryption ─────────────────────────────────────────────────────────────
# AES-256-GCM key used to encrypt user-supplied LLM provider keys at rest.
# MUST be exactly 64 hex characters (32 bytes).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="<64-hex-char-string>"

# ── LLM Mock ───────────────────────────────────────────────────────────────
# Set to "true" to bypass all real LLM provider calls (tests / CI).
MOCK_MODE="false"

# Configurable delay in milliseconds for simulated pipeline staging (Default: 500)
MOCK_PIPELINE_DELAY_MS="500"
